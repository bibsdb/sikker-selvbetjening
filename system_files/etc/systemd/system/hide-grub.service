[Unit]
Description=Configure Kiosk GRUB Hidden Backdoor
DefaultDependencies=no
After=local-fs.target
Before=sysinit.target

[Service]
Type=oneshot
ExecStart=/usr/bin/grub2-editenv - set menu_auto_hide=1
ExecStart=/usr/bin/grub2-editenv - set timeout=3
RemainAfterExit=yes

[Install]
WantedBy=sysinit.target