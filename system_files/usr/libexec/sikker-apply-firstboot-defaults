#!/bin/bash

set -euo pipefail

install -Dm0644 /usr/lib/sikker-selvbetjening/defaults/hostname /etc/hostname
install -Dm0644 /usr/lib/sikker-selvbetjening/defaults/timezone /etc/timezone

timezone="$(tr -d '\n' </usr/lib/sikker-selvbetjening/defaults/timezone)"
ln -snf "/usr/share/zoneinfo/${timezone}" /etc/localtime

if command -v hostname >/dev/null 2>&1; then
	hostname -F /etc/hostname || true
fi