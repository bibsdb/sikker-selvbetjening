#!/bin/bash
set -euo pipefail

CONFIG_ROOT="${1:?config root required}"
OUTPUT_ROOT="${2:?output root required}"

DESKTOP_CONF="${CONFIG_ROOT}/desktop.conf"
ASSETS_DIR="${CONFIG_ROOT}/assets"

# No desktop config means no background config to emit
[[ -f "${DESKTOP_CONF}" ]] || exit 0

# Read background_image_file from rendered desktop.conf
bg="$(sed -nE 's/^[[:space:]]*background_image_file[[:space:]]*=[[:space:]]*//p' "${DESKTOP_CONF}" | head -n1)"
bg="${bg#\"}"; bg="${bg%\"}"
bg="${bg#\'}"; bg="${bg%\'}"

[[ -n "${bg}" ]] || exit 0

src="${ASSETS_DIR}/${bg}"
[[ -f "${src}" ]] || { echo "Missing background image: ${src}" >&2; exit 1; }

# Copy to stable system path in output tree
mkdir -p "${OUTPUT_ROOT}/usr/share/backgrounds/sikker-selvbetjening"
cp -f "${src}" "${OUTPUT_ROOT}/usr/share/backgrounds/sikker-selvbetjening/default-background"

# Emit final dconf defaults directly into output tree
mkdir -p "${OUTPUT_ROOT}/etc/dconf/db/local.d"
cat > "${OUTPUT_ROOT}/etc/dconf/db/local.d/03-desktop-background" <<EOF
[org/gnome/desktop/background]
picture-uri='file:///usr/share/backgrounds/sikker-selvbetjening/default-background'
picture-uri-dark='file:///usr/share/backgrounds/sikker-selvbetjening/default-background'
picture-options='zoom'
primary-color='#000000'
secondary-color='#000000'
EOF
